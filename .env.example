# ─── Gmail API credentials (from Google Cloud Console) ───
GMAIL_CLIENT_ID=your_google_client_id
GMAIL_CLIENT_SECRET=your_google_client_secret

# Local:   http://localhost:3001/auth/google/callback
# Railway: https://YOUR-APP.up.railway.app/auth/google/callback
GMAIL_REDIRECT_URI=http://localhost:3001/auth/google/callback

# ─── Anthropic API key (for Claude Haiku curation) ───
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── JWT secret for session tokens ───
# Generate a strong random string, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret

# ─── Email delivery via Resend (resend.com) ───
# Sign up free at resend.com, copy your API key here
RESEND_API_KEY=re_your_api_key_here
# Optional: customize the sender (requires a verified domain in Resend)
# RESEND_FROM_EMAIL=The Digestino <digest@yourdomain.com>

# ─── App URL (only needed for Railway / production) ───
# Set this to your Railway public URL, e.g. https://YOUR-APP.up.railway.app
# APP_URL=

# ─── Server port (Railway sets this automatically) ───
PORT=3001
